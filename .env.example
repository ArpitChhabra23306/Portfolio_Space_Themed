# Site URL (required for production build — used in sitemap, JSON-LD, OG tags)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# EmailJS (contact form)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxx

# Stats API — upstream handles
LEETCODE_USERNAME=your_leetcode_username
CODEFORCES_HANDLE=your_codeforces_handle
GITHUB_USERNAME=your_github_username

# GitHub PAT (fine-grained, read-only public scope) — needed for contribution calendar GraphQL
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
